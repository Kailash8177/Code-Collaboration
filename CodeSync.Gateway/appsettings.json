{
  "Jwt": {
    "Secret": "CodeSync_JWT_Secret_Key_2026_Min32Chars!!",
    "Issuer": "CodeSync",
    "Audience": "CodeSync"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-public-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Public",
        "Match": {
          "Path": "/gateway/auth/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/api/auth/{**catch-all}" }],
        "Metadata": {
          "RateLimit.Policy": "auth-policy"
        }
      },

      "projects-route": {
        "ClusterId": "project-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/projects/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/api/projects/{**catch-all}" }],
        "Metadata": {
          "RateLimit.Policy": "standard-policy"
        }
      },

      "files-route": {
        "ClusterId": "file-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/files/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/api/files/{**catch-all}" }],
        "Metadata": {
          "RateLimit.Policy": "standard-policy"
        }
      },

      "sessions-route": {
        "ClusterId": "collab-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/sessions/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/api/sessions/{**catch-all}" }],
        "Metadata": {
          "RateLimit.Policy": "standard-policy"
        }
      },

      "executions-route": {
        "ClusterId": "execution-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/executions/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/api/executions/{**catch-all}" }],
        "Metadata": {
          "RateLimit.Policy": "execution-policy"
        }
      },

      "snapshots-route": {
        "ClusterId": "reviewhub-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/snapshots/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/api/snapshots/{**catch-all}" }],
        "Metadata": {
          "RateLimit.Policy": "standard-policy"
        }
      },

      "comments-route": {
        "ClusterId": "reviewhub-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/comments/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/api/comments/{**catch-all}" }],
        "Metadata": {
          "RateLimit.Policy": "standard-policy"
        }
      },

      "notifications-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/notifications/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/api/notifications/{**catch-all}" }],
        "Metadata": {
          "RateLimit.Policy": "standard-policy"
        }
      },

      "collab-hub-route": {
        "ClusterId": "collab-cluster",
        "AuthorizationPolicy": "Public",
        "Match": {
          "Path": "/gateway/hubs/collab/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/hubs/collab/{**catch-all}" }]
      },

      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "Public",
        "Match": {
          "Path": "/gateway/hubs/notifications/{**catch-all}"
        },
        "Transforms": [{ "PathPattern": "/hubs/notifications/{**catch-all}" }]
      }
    },

    "Clusters": {
      "auth-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "auth-primary": {
            "Address": "http://localhost:7001/"
          }
        }
      },

      "project-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "project-primary": {
            "Address": "http://localhost:7002/"
          }
        }
      },

      "file-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "file-primary": {
            "Address": "http://localhost:7003/"
          }
        }
      },

      "collab-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "collab-primary": {
            "Address": "http://localhost:7004/"
          }
        }
      },

      "execution-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:15",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "execution-primary": {
            "Address": "http://localhost:7005/"
          }
        }
      },

      "reviewhub-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "reviewhub-primary": {
            "Address": "http://localhost:7006/"
          }
        }
      },

      "notification-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "notification-primary": {
            "Address": "http://localhost:7007/"
          }
        }
      }
    }
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "QuotaExceededMessage": "Rate limit exceeded. Please slow down.",
    "GeneralRules": [
      {
        "Endpoint": "*:/gateway/auth/*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "*:/gateway/executions/*",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },

  "AllowedHosts": "*",
  "Urls": "http://localhost:5000"
}
